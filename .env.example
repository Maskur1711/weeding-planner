# ==========================================================================
# Wedding Planner — Environment Variables
# ==========================================================================
# Salin file ini menjadi ".env" (lokal) atau set di Railway dashboard (prod).
# ==========================================================================

# --- Database (PostgreSQL) ---
# Lokal Jalur A (Railway Postgres): copy DATABASE_URL dari Railway dashboard
# Lokal Jalur B (docker-compose)  : postgresql://postgres:postgres@localhost:5432/wedding?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wedding?schema=public"

# --- Bot Baileys ---
# Folder penyimpanan auth state (QR pairing). WAJIB persistent di Railway.
# Lokal   : ./auth_info
# Railway : /data/auth_info (dengan volume mount di /data)
AUTH_FOLDER="./auth_info"

# --- Opsional: whitelist nomor pengirim (format: 62812xxxx,62813xxxx) ---
# Kosongkan = terima dari siapa saja
ALLOWED_SENDERS=""

# --- Opsional: nama pemilik untuk pesan sapaan bot ---
OWNER_NAME=""
